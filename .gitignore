# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
*.tsbuildinfo

# ── Environment / secrets ─────────────────────────────────────────────────────
# Never commit secrets. .env.local is the developer-local override;
# .env.*.local covers any env-specific variants (e.g. .env.test.local).
.env
.env.local
.env.*.local

# ── Test coverage ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── OS metadata ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── Editor / IDE (machine-specific state) ─────────────────────────────────────
# .vscode/extensions.json is useful to track (suggests extensions to contributors).
# Everything else in .vscode/ is machine-specific.
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── Package manager debug logs ────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Runtime / temporary directories ──────────────────────────────────────────
# tmp-* covers smoke-test trees (`tmp-smoke/`), CI scratch dirs, and any
# throwaway trees created by RELEASE-CHECKLIST.md walkthroughs.
tmp*/

# ── ai-memory project-specific ────────────────────────────────────────────────

# Machine-local extraction state. The memories themselves (.ai-memory/**/*.md)
# ARE committed — that's the whole point of the tool. Only machine-specific
# indexes and logs are excluded here.
.ai-memory/.state.json
.ai-memory/.embeddings.json
.ai-memory/schedule.log

# CCEB benchmark live output (regenerated on every run).
# The published baseline lives in docs/benchmarks/cceb-baseline.md.
bench/cceb/out/

# LongMemEval: large dataset (~265 MB) and live run output are excluded
# via bench/longmemeval/.gitignore (data/ + out/).

# Demo scenario byproduct: AGENTS.md is generated by `npm run demo:render`
# inside the staged scenario. We ship the inputs (.ai-memory/) and the
# rendered GIF, but not the intermediate file — it would silently rot
# whenever the rules writer changes.
docs/assets/demo/scenario/AGENTS.md
