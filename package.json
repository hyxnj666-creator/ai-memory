{
  "name": "ai-memory-cli",
  "version": "2.4.0",
  "description": "Turn editor chat history (Cursor, Claude Code, Windsurf, Copilot) into typed Markdown decisions + AGENTS.md rules — local-first, git-trackable, zero remember() calls.",
  "type": "module",
  "bin": {
    "ai-memory": "dist/index.js"
  },
  "main": "./dist/public.js",
  "types": "./dist/public.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench:cceb": "tsx bench/cceb/run.ts",
    "bench:cceb:dry": "tsx bench/cceb/run.ts --dry-run",
    "demo:render": "vhs docs/assets/demo/demo.tape",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "agents-md",
    "ai",
    "memory",
    "cursor",
    "claude-code",
    "windsurf",
    "github-copilot",
    "knowledge-extraction",
    "knowledge-pipeline",
    "chat-history",
    "conversation-history",
    "developer-tools",
    "local-first",
    "cli",
    "mcp",
    "mcp-server",
    "semantic-search"
  ],
  "author": "Conor Liu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyxnj666-creator/ai-memory"
  },
  "homepage": "https://github.com/hyxnj666-creator/ai-memory#readme",
  "bugs": {
    "url": "https://github.com/hyxnj666-creator/ai-memory/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  }
}
